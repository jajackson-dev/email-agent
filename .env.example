# Gmail OAuth2 credentials
# See setup instructions in the README or deployment guide
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# The Gmail address used to send emails (must match the OAuth2 account)
GMAIL_USER=you@gmail.com

# Where owner notification emails are delivered
OWNER_EMAIL=you@yourdomain.com

# Displayed in email templates and subject lines
BUSINESS_NAME=Your Business Name
